# ─── Supabase ──────────────────────────────────────────────

# Frontend (Vite exposes VITE_ prefix vars to the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side (Netlify functions only — never exposed to browser)
# NOTE: Use SUPABASE_URL / SUPABASE_ANON_KEY (no VITE_ prefix) for server vars.
# The upload-voice function reads these; do NOT rely on VITE_ vars server-side.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here # ⚠️ Keep secret!

# ─── Groq AI ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here

# ─── Web Push (VAPID) ────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here  # Safe to expose to browser
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here     # ⚠️ Keep secret!
VAPID_EMAIL=mailto:your@email.com

# ─── Webhook secret ──────────────────────────────────────────
# Used to authenticate Supabase → Netlify push-send webhook.
# ⚠️ SERVER-SIDE ONLY — never prefix this with VITE_ or it will be
# bundled into your frontend build and visible to anyone in DevTools.
WEBHOOK_SECRET=a_long_random_string_here

# ─── Daily Accumulator (Betting) ────────────────────────────
# You need AT LEAST ONE of these two keys for the accumulator to work.
#
# OPTION A (recommended): The Odds API — 500 free requests/month
#   Sign up: https://the-odds-api.com
#   Better odds coverage, more sports, more reliable on free tier.
THE_ODDS_API_KEY=your_odds_api_key_here

# OPTION B (fallback): API-Football — 100 free requests/day
#   Sign up: https://dashboard.api-football.com/register
#   If THE_ODDS_API_KEY is also set, this is used as a fallback only.
API_FOOTBALL_KEY=your_api_football_key_here

# ─── Betpaddi (SportyBet booking code generation) ────────────
# Sign up: https://betpaddi.com — used to auto-generate accumulator booking codes.
# ⚠️ NEVER hardcode this as a fallback — always load from env vars only.
BETPADDI_API_KEY=BP-your_betpaddi_key_here

# Protects the POST /generate and PATCH /result endpoints
# Generate: openssl rand -hex 32
CRON_SECRET=a_long_random_secret_here

# Comma-separated admin emails — shows Mark Won/Lost buttons in UI
VITE_ADMIN_EMAILS=your@email.com

# ─── Site URL (for CORS) ─────────────────────────────────────
# Set this in Netlify → Site settings → Environment variables.
# Netlify injects it automatically on deploy; set it manually for branch deploys.
# All Netlify functions use this to restrict CORS to your domain.
SITE_URL=https://vii-mbuni.netlify.app

# ─── WebRTC TURN servers (relay.metered.ca free tier) ────────
# These credentials come from your Metered.ca dashboard (free plan).
# NEVER hardcode them in source — store here for local dev, set in Netlify env vars for prod.
TURN_USERNAME=your_metered_username_here
TURN_CREDENTIAL=your_metered_credential_here

# For production, set METERED_API_KEY to get fresh short-lived credentials:
METERED_API_KEY=your_metered_api_key_here
METERED_DOMAIN=vii-mbuni.metered.live
