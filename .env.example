# ─── Supabase ──────────────────────────────────────────────

# Frontend (Vite exposes VITE_ prefix vars to the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side (Netlify functions only — never exposed to browser)
# NOTE: Use SUPABASE_URL / SUPABASE_ANON_KEY (no VITE_ prefix) for server vars.
# The upload-voice function reads these; do NOT rely on VITE_ vars server-side.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here # ⚠️ Keep secret!

# ─── Groq AI ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here

# ─── Web Push (VAPID) ────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here  # Safe to expose to browser
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here     # ⚠️ Keep secret!
VAPID_EMAIL=mailto:your@email.com

# ─── Webhook secret ──────────────────────────────────────────
# Used to authenticate Supabase → Netlify push-send webhook.
# ⚠️ SERVER-SIDE ONLY — never prefix this with VITE_ or it will be
# bundled into your frontend build and visible to anyone in DevTools.
WEBHOOK_SECRET=a_long_random_string_here

# ─── Site URL (for CORS) ─────────────────────────────────────
# Set this in Netlify → Site settings → Environment variables.
# Netlify injects it automatically on deploy; set it manually for branch deploys.
# All Netlify functions use this to restrict CORS to your domain.
SITE_URL=https://vii-mbuni.netlify.app
